{erl_opts, [debug_info]}.

%% Xref configuration - ignore unused exports (these are public API)
{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

%% Dialyzer configuration
{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling
    ]},
    {plt_extra_apps, [cowboy, ranch]}
]}.

{deps, [
    {cowboy, "2.12.0"},
    %% TODO: Point back to benoitc/erlang-python main (or a release tag) once
    %% https://github.com/benoitc/erlang-python/pull/9 is merged.
    {erlang_python, {git, "https://github.com/h0rv/erlang-python.git", {branch, "feature/combined-for-hornbeam"}}}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps, [hornbeam]}
]}.

{relx, [{release, {hornbeam, "1.4.1"},
         [hornbeam,
          sasl]},

        {mode, dev},

        {extended_start_script, true}]}.

{profiles, [
    {test, [
        {deps, [
            {hackney, "3.0.2"},
            {jsx, "3.1.0"}
        ]}
    ]}
]}.

{project_plugins, [rebar3_ex_doc]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/benoitc/hornbeam">>},
    {homepage_url, <<"https://hornbeam.dev">>},
    {main, <<"readme">>},
    {extras, [
        <<"README.md">>,
        <<"CHANGELOG.md">>
    ]}
]}.
