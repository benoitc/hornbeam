[
    {hornbeam, [
        {bind, "127.0.0.1:8000"},
        {workers, 4},
        {worker_class, wsgi},
        {timeout, 30000},
        {keepalive, 2},
        {max_requests, 1000},
        {preload_app, false},
        {pythonpath, [".", "examples"]},
        %% WSGI body streaming settings
        {wsgi_body_chunk_size, 65536},      %% 64KB chunks
        {wsgi_streaming_threshold, 65536}   %% Stream if > 64KB
    ]},
    {erlang_python, [
        {num_workers, 4},
        {max_concurrent, 10000}
    ]}
].
